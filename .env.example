# Required for Claude generators/judge
ANTHROPIC_API_KEY=

# Optional - enables GPT as a second generator/judge
OPENAI_API_KEY=

# Optional - enables Gemini (routed via OpenAI-compatible endpoint)
GEMINI_API_KEY=

# Optional - enables DataForSEO keyword enrichment (search volume, keyword
# difficulty, related keywords). Without these, keyword suggestions are
# ungrounded and the UI shows "not connected". See config/dataforseo.yaml to
# switch between sandbox (free, dummy data) and live mode.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
